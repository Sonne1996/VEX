  "keywords": [
    "automatic short answer grading",
    "ASAG",
    "virtual exams",
    "benchmark evaluation",
    "model predictions",
    "VEX",
    "predominantly German",
    "mixed-language responses"
  ],
  "additionalProperty": [
    {
      "@type": "sc:PropertyValue",
      "name": "Language distribution",
      "value": "Predominantly German. A small minority of responses may contain English or mixed German-English text."
    },
    {
      "@type": "sc:PropertyValue",
      "name": "Primary release artifact",
      "value": "vex_metric_dataset/merged_model_predictions.parquet"
    },
    {
      "@type": "sc:PropertyValue",
      "name": "Record granularity",
      "value": "One record per answer-level grading instance with reference grades and prediction columns from all released model families."
    },
    {
      "@type": "sc:PropertyValue",
      "name": "Label scale",
      "value": "Five-point normalized ordinal grading scale: 0.0, 0.25, 0.5, 0.75, 1.0."
    }
  ],
