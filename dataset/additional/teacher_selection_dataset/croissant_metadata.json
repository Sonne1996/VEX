  "dct:conformsTo": "http://mlcommons.org/croissant/1.1",
  "description": "Derived VEX dataset for teacher-model selection on the gold subset. It combines answer-level gold context, audit metadata, candidate teacher outputs, and evaluator-model grades used to compare teacher candidates before silver-label generation.",
  "license": "https://creativecommons.org/licenses/by/4.0/",
  "sdLicense": "https://creativecommons.org/licenses/by/4.0/",
  "url": "https://github.com/Sonne1996/VEX/tree/main/dataset/additional/teacher_selection_dataset",
  "isAccessibleForFree": true,
  "inLanguage": [
    {
      "@type": "sc:Language",
      "name": "German",
      "alternateName": "de"
    },
    {
      "@type": "sc:Language",
      "name": "English",
      "alternateName": "en"
    }
  ],
  "keywords": [
    "automatic short answer grading",
    "ASAG",
    "teacher model selection",
    "silver labels",
    "gold evaluation",
    "VEX",
    "predominantly German",
    "mixed-language responses"
  ],
  "additionalProperty": [
    {
      "@type": "sc:PropertyValue",
      "name": "Language distribution",
      "value": "Predominantly German. A small minority of responses may contain English or mixed German-English text."
    },
    {
      "@type": "sc:PropertyValue",
      "name": "Primary release artifact",
      "value": "teacher_selection_dataset/gold_with_all_models.parquet"
    },
    {
      "@type": "sc:PropertyValue",
      "name": "Record granularity",
      "value": "One record per gold answer-level grading instance with teacher-candidate outputs and evaluator-model scores."
    },
    {
      "@type": "sc:PropertyValue",
      "name": "Label scale",
      "value": "Five-point normalized ordinal grading scale: 0.0, 0.25, 0.5, 0.75, 1.0."
    }
  ],
