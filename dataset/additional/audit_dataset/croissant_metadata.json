{
  "@context": {
    "@language": "en",
    "@vocab": "http://schema.org/",
    "sc": "http://schema.org/",
    "cr": "http://mlcommons.org/croissant/",
    "dct": "http://purl.org/dc/terms/"
  },
  "@type": "sc:Dataset",
  "@id": "https://github.com/Sonne1996/VEX/tree/main/dataset/additional/audit_dataset",
  "name": "VEX Audit Dataset",
  "version": "1.0.0",
  "dct:conformsTo": "http://mlcommons.org/croissant/1.1",
  "description": "Derived VEX dataset for annotation and audit analysis. It preserves the answer-level records together with the human annotation, consensus, and manual-audit columns that are removed from cleaner benchmark-facing releases.",
  "license": "https://creativecommons.org/licenses/by/4.0/",
  "sdLicense": "https://creativecommons.org/licenses/by/4.0/",
  "url": "https://github.com/Sonne1996/VEX/tree/main/dataset/additional/audit_dataset",
  "isAccessibleForFree": true,
  "inLanguage": [
    {
      "@type": "sc:Language",
      "name": "German",
      "alternateName": "de"
    },
    {
      "@type": "sc:Language",
      "name": "English",
      "alternateName": "en"
    }
  ],
  "keywords": [
    "automatic short answer grading",
    "ASAG",
    "annotation audit",
    "gold labels",
    "educational assessment",
    "VEX",
    "predominantly German",
    "mixed-language responses"
  ],
  "additionalProperty": [
    {
      "@type": "sc:PropertyValue",
      "name": "Language distribution",
      "value": "Predominantly German. A small minority of responses may contain English or mixed German-English text."
    },
    {
      "@type": "sc:PropertyValue",
      "name": "Primary release artifact",
      "value": "audit_dataset/audit_dataset.parquet"
    },
    {
      "@type": "sc:PropertyValue",
      "name": "Record granularity",
      "value": "One record per answer-level grading instance with preserved annotation and audit metadata."
    }
  ],
  "distribution": [
    {
      "@type": "cr:FileObject",
      "@id": "audit_dataset_parquet",
      "name": "audit_dataset.parquet",
      "description": "Derived VEX audit dataset artifact.",
      "contentUrl": "https://raw.githubusercontent.com/Sonne1996/VEX/main/dataset/additional/audit_dataset/audit_dataset.parquet",
      "encodingFormat": "application/vnd.apache.parquet"
    }
  ],
  "recordSet": [
    {
      "@type": "cr:RecordSet",
      "@id": "audit_records",
      "name": "Audit Records",
      "description": "One record per student answer in the VEX audit dataset. Each record combines anonymized identifiers, question and answer text, the normalized reference grade, split and provenance fields, and the preserved annotation, consensus, and manual-audit columns required for audit-focused analysis.",
      "key": [
        {
          "@id": "audit_records/grading_id"
        }
      ],
      "field": [
        {
          "@type": "cr:Field",
          "@id": "audit_records/member_id",
          "name": "member_id",
          "description": "Anonymous student identifier.",
          "dataType": "sc:Text",
          "source": {
            "fileObject": {
              "@id": "audit_dataset_parquet"
            },
            "extract": {
              "column": "member_id"
            }
          }
        },
        {
          "@type": "cr:Field",
          "@id": "audit_records/subject_id",
