  "dct:conformsTo": "http://mlcommons.org/croissant/1.1",
  "description": "VEX v0.3 Stable is the first stable VEX dataset version aligned with the downstream modeling pipeline. It contains one record per student short-answer response, with anonymized identifiers, cleaned question and answer text, question metadata, a normalized ordinal grade, a train/test split, and label provenance indicating gold versus silver supervision.",
  "license": "https://creativecommons.org/licenses/by/4.0/",
  "sdLicense": "https://creativecommons.org/licenses/by/4.0/",
  "url": "https://github.com/Sonne1996/VEX/tree/main/dataset/vex",
  "isAccessibleForFree": true,
  "keywords": [
    "automatic short answer grading",
    "ASAG",
    "educational assessment",
    "virtual exams",
    "benchmark dataset",
    "German higher education",
    "short-answer grading"
  ],
